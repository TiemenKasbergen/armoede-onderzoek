install.packages(c("tidyverse", "ggplot2", "readr", "dplyr"))
knitr::opts_chunk$set(echo = TRUE)
library(tidyverse)
library(tidyverse)
# Data inladen (gebruik ; als scheidingsteken want CBS gebruikt dat)
obs <- read_csv2("Observations.csv")
kenmerken <- read_csv2("KenmerkenVanHuishoudensCodes.csv")
perioden <- read_csv2("PeriodenCodes.csv")
# Jaar netjes maken (2011JJ00 -> 2011)
obs <- obs %>%
mutate(jaar = as.integer(substr(Perioden, 1, 4)))
# Codes koppelen aan leesbare namen
obs <- obs %>%
left_join(kenmerken %>% select(Identifier, Title),
by = c("KenmerkenVanHuishoudens" = "Identifier"))
head(obs)
obs %>% select(KenmerkenVanHuishoudens, Title, jaar, Value) %>% head(10)
# Alleen de percentages (de kleine getallen)
armoede_pct <- obs %>%
filter(Title == "Particuliere huishoudens",
Value < 20)  # percentages zijn klein
ggplot(armoede_pct, aes(x = jaar, y = Value)) +
geom_line(color = "steelblue", size = 1) +
geom_point(color = "steelblue") +
labs(title = "Armoede in Nederland over de tijd",
x = "Jaar",
y = "% huishoudens onder armoedegrens") +
theme_minimal()
